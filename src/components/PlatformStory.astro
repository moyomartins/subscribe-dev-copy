---
const providers = [
  { mark: 'O', provider: 'OpenAI', name: 'Text generation', model: 'openai/gpt-4o', tier: 'Pro +' },
  { mark: 'B', provider: 'Black Forest Labs', name: 'Image generation', model: 'black-forest-labs/flux-schnell', tier: 'Free +' },
  { mark: 'W', provider: 'Wan', name: 'Video generation', model: 'wan-video/wan-2.2-5b-fast', tier: 'Max' },
  { mark: 'E', provider: 'ElevenLabs', name: 'Speech generation', model: 'speech/*', tier: 'Pro +' },
  { mark: 'A', provider: 'Anthropic', name: 'Reasoning', model: 'claude-sonnet', tier: 'Pro +' },
  { mark: 'G', provider: 'Google', name: 'Multimodal', model: 'gemini-2.5-pro', tier: 'Pro +' },
];

const plans = [
  { name: 'Free', price: '$0 / month', credits: '20', models: 'Starter set', limit: '20 credits', width: '16%' },
  { name: 'Pro', price: '$29 / month', credits: '200', models: 'Expanded access', limit: '200 credits', width: '52%', featured: true },
  { name: 'Max', price: '$99 / month', credits: '1,000', models: '100+ models', limit: '1,000 credits', width: '94%' },
];

const flow = ['Application', 'subscribe.dev SDK', 'Billing', 'Usage metering', 'Access control', 'AI models'];
---

<section class="architecture on-paper" id="architecture">
  <div class="wrap">
    <div class="section-copy enter">
      <h2>Full-stack product infrastructure, delivered to your frontend.</h2>
      <p>
        The secure client resolves identity, subscription tier, available credits,
        and billing state before a request reaches an AI model.
      </p>
    </div>

    <div class="architecture-map enter" id="request-flow" data-outcome="allowed" style="--i: 1" aria-label="Animated subscribe.dev product architecture">
      <svg class="architecture-connectors" aria-hidden="true">
        <path data-connector="user"></path>
        <path data-connector="app"></path>
        <path data-connector="models"></path>
        <path data-connector="stripe"></path>
        <path data-connector="credits"></path>
        <circle class="connector-pulse" data-connector-pulse="left" r="4"></circle>
        <circle class="connector-pulse" data-connector-pulse="right" r="4"></circle>
      </svg>

      <div class="arch-side arch-inputs">
        <p class="map-label">Your product</p>
        <div class="arch-node" data-flow-node="user"><span class="node-icon">U</span><span><b>Users</b><small>user_ada_93</small></span></div>
        <div class="arch-node" data-flow-node="app"><span class="node-icon">A</span><span><b>Frontend application</b><small>React, Vite, or Bun</small></span></div>
      </div>

      <div class="arch-lines" aria-hidden="true"></div>

      <div class="control-plane">
        <div class="plane-head">
          <span class="signal"></span>
          <strong>subscribe.dev</strong>
          <code>request gate</code>
        </div>
        <div class="plane-grid">
          <div data-phase="auth"><span>01</span><b>Authenticate</b><small>Resolve user scope</small></div>
          <div data-phase="plan"><span>02</span><b>Check plan</b><small>Apply model policy</small></div>
          <div data-phase="usage"><span>03</span><b>Meter usage</b><small>Reserve 4 credits</small></div>
          <div data-phase="billing"><span>04</span><b>Record billing</b><small>Sync with Stripe</small></div>
        </div>
        <div class="request-log">
          <span class="ok-dot"></span>
          <code data-flow-bind="request">POST /run/flux-schnell</code>
          <strong data-flow-bind="status">checking...</strong>
          <span data-flow-bind="latency">—</span>
        </div>
      </div>

      <div class="arch-lines" aria-hidden="true"></div>

      <div class="arch-side arch-outputs">
        <p class="map-label">Managed infrastructure</p>
        <div class="arch-node" data-flow-output="models"><span class="node-icon">M</span><span><b>100+ AI models</b><small>Text, image, video, speech</small></span></div>
        <div class="arch-node" data-flow-output="stripe"><span class="node-icon">$</span><span><b>Stripe payments</b><small>Subscriptions + renewals</small></span></div>
        <div class="arch-node" data-flow-output="credits"><span class="node-icon">#</span><span><b>Credit limits</b><small>Automatic per user</small></span></div>
      </div>
    </div>
  </div>
</section>

<section class="model-access" id="models">
  <div class="wrap">
    <div class="section-copy enter">
      <h2>Run 100+ generative AI models through one client.</h2>
      <p>Generate text, images, video, and speech. Change a model string; subscribe.dev handles secure user-scoped access.</p>
    </div>

    <div class="code-result model-router enter" id="model-router" style="--i: 1">
      <figure class="code-card dark-card">
        <figcaption><span>Generate.tsx</span><span>frontend</span></figcaption>
        <pre><code><span class="muted">const</span> {'{'} client, usage, subscriptionStatus {'}'} =
  useSubscribeDev()

<span class="muted">const</span> result = <span class="muted">await</span> client.run(
  <span class="green active-model-string">'black-forest-labs/flux-schnell'</span>,
  {'{'}
    input: {'{'} prompt: <span class="green">'A lighthouse at dawn'</span> {'}'}
  {'}'}
)

<span class="muted">// Secure user scope and credit usage</span>
console.log(usage, subscriptionStatus)</code></pre>
        <div class="terminal-line"><span>client.run()</span><code data-router-bind="terminal">flux-schnell → -4 credits</code><strong data-router-bind="status">COMPLETE</strong></div>
      </figure>

      <div class="model-connector" aria-hidden="true"><i></i><span></span></div>

      <div class="catalog-card paper-card">
        <div class="card-head">
          <div><span class="eyebrow">Model access</span><h3>Catalog policy</h3></div>
          <span class="status-pill">Live</span>
        </div>
        <div class="catalog-summary">
          <span><b>100+</b><small>AI models</small></span>
          <span><b>4</b><small>modalities</small></span>
          <span><b>1</b><small>run() call</small></span>
        </div>
        <div class="provider-strip" aria-label="Supported providers">
          {providers.filter((provider) => ['OpenAI', 'Anthropic', 'Google', 'Black Forest Labs', 'ElevenLabs'].includes(provider.provider)).map((provider) => (
            <span data-provider={provider.provider}>{provider.provider}</span>
          ))}
        </div>
        <ul class="provider-list">
          {providers.map((provider) => (
            <li data-model={provider.model} data-provider={provider.provider}>
              <span class="provider-mark">{provider.mark}</span>
              <span class="provider-name"><b>{provider.name}</b><code>{provider.model}</code></span>
              <span class="provider-tier">{provider.tier}</span>
              <span class="provider-state">Enabled</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="tiers on-paper">
  <div class="wrap">
    <div class="section-copy enter">
      <h2>Take subscription payments. Enforce the tier automatically.</h2>
      <p>Free, Pro, and Max plans become secure per-user model access and credit limits, with payments powered by Stripe.</p>
    </div>

    <div class="tier-engine enter" id="policy-engine" style="--i: 1">
      <div class="tier-toolbar">
        <span><i></i> Access policy</span>
        <code>plans.config.ts</code>
        <span class="policy-deploy-status" data-policy-bind="deploy">Monitoring plan usage</span>
        <button type="button" data-policy-bind="button">Policies live</button>
        <span class="policy-cursor" aria-hidden="true"></span>
        <div class="policy-progress" aria-hidden="true"><i></i></div>
      </div>
      <div class="tier-grid">
        <div class="policy-signal" aria-hidden="true"><i></i></div>
        {plans.map((plan, index) => (
          <article class:list={['tier-card', { featured: plan.featured }]} data-policy-plan={index}>
            <div class="tier-top">
              <h3>{plan.name}</h3>
              <span class="tier-state" data-policy-bind="badge">{plan.name === 'Free' ? 'Monitoring' : 'Standby'}</span>
              <span>{plan.price}</span>
            </div>
            <dl>
              <div><dt>Monthly credits</dt><dd>{plan.credits}</dd></div>
              <div><dt>Model access</dt><dd>{plan.models}</dd></div>
              <div><dt>User spend limit</dt><dd>{plan.limit}</dd></div>
            </dl>
            <div class="access-track"><i style={`--fill: ${plan.width}`}></i></div>
            <p data-policy-bind="plan-status">{plan.name === 'Free' ? 'Usage available' : plan.name === 'Pro' ? 'Subscription operating' : 'Unlimited access operating'}</p>
          </article>
        ))}
      </div>
      <div class="policy-footer">
        <span data-policy-footer="0"><i class="ok-dot"></i><code>Stripe billing active</code></span>
        <span data-policy-footer="1"><i class="ok-dot"></i>Access policy checked</span>
        <span data-policy-footer="2"><i class="ok-dot"></i>Free limit enforced</span>
        <span data-policy-footer="3"><i class="ok-dot"></i><strong>Pro + Max continue</strong></span>
      </div>
    </div>
  </div>
</section>

<section class="metering">
  <div class="wrap">
    <div class="section-copy enter">
      <h2>User-scoped credit limits stop overspend automatically.</h2>
      <p>Track consumption and credits remaining for every subscriber. When a user reaches their tier limit, access stops safely.</p>
    </div>

    <div class="container-scroll-stage enter" id="metering-scroll" style="--i: 1">
      <div class="container-scroll-sticky">
        <div class="scroll-dashboard-frame">
          <div class="scroll-dashboard screenshot-dashboard">
            <img src="/images/subscribe-dashboard-frame.png" alt="subscribe.dev dashboard overview" />
          </div>
        </div>
        <div class="scroll-dashboard-glow" aria-hidden="true"></div>
      </div>
    </div>

    <div class="dashboard-frame coded-dashboard retired-dashboard" aria-hidden="true">
      <div class="dashboard-frame-bar" aria-hidden="true">
        <span class="frame-dots"><i></i><i></i><i></i></span>
        <span class="frame-address">platform.subscribe.dev/dashboard</span>
        <span class="frame-live"><i></i>Live product</span>
      </div>
      <div class="product-dashboard retired-dashboard" id="usage-dashboard">
        <svg class="dashboard-icon-sprite" aria-hidden="true">
          <symbol id="d-layout" viewBox="0 0 24 24"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></symbol>
          <symbol id="d-folder" viewBox="0 0 24 24"><path d="M3 7h5l2 2h11v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/><path d="M3 7V5a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v2"/></symbol>
          <symbol id="d-users" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></symbol>
          <symbol id="d-card" viewBox="0 0 24 24"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></symbol>
          <symbol id="d-code" viewBox="0 0 24 24"><path d="m8 9-4 3 4 3m8-6 4 3-4 3m-2-9-4 12"/></symbol>
          <symbol id="d-user" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></symbol>
          <symbol id="d-wallet" viewBox="0 0 24 24"><path d="M20 7V5a2 2 0 0 0-2-2H5a3 3 0 0 0 0 6h15v10H5a3 3 0 0 1-3-3V6"/><path d="M16 13h2"/></symbol>
          <symbol id="d-key" viewBox="0 0 24 24"><circle cx="8" cy="15" r="4"/><path d="m11 12 8-8m-3 3 3 3m-6 0 3 3"/></symbol>
          <symbol id="d-search" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></symbol>
          <symbol id="d-download" viewBox="0 0 24 24"><path d="M12 3v12m-5-5 5 5 5-5M5 21h14"/></symbol>
          <symbol id="d-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="M12 8v4m0 4h.01"/></symbol>
          <symbol id="d-activity" viewBox="0 0 24 24"><path d="M3 12h4l2-7 4 14 2-7h6"/></symbol>
          <symbol id="d-battery" viewBox="0 0 24 24"><rect width="16" height="10" x="3" y="7" rx="2"/><path d="M21 11v2M7 11v2m4-2v2"/></symbol>
          <symbol id="d-alert" viewBox="0 0 24 24"><path d="m21 19-9-16-9 16Z"/><path d="M12 9v4m0 4h.01"/></symbol>
          <symbol id="d-check" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/></symbol>
          <symbol id="d-plus" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 8v8m-4-4h8"/></symbol>
          <symbol id="d-x" viewBox="0 0 24 24"><path d="m7 7 10 10M17 7 7 17"/></symbol>
        </svg>
        <aside class="product-sidebar">
          <div class="product-user">
            <span class="product-avatar">JD</span>
            <span><b>John Doe</b><small>john.doe@example.com</small></span>
          </div>
          <div class="product-nav-group">
            <small>Overview</small>
            <nav aria-label="Product dashboard navigation">
              <span><svg><use href="#d-layout"></use></svg>Dashboard</span><span><svg><use href="#d-folder"></use></svg>Projects</span><button class="active" data-dashboard-view="Users"><svg><use href="#d-users"></use></svg>Users</button><span><svg><use href="#d-card"></use></svg>Transactions</span><span><svg><use href="#d-code"></use></svg>Playground</span>
            </nav>
          </div>
          <div class="product-nav-group">
            <small>Account</small>
            <nav><span><svg><use href="#d-user"></use></svg>Account Profile</span><span><svg><use href="#d-wallet"></use></svg>Wallet</span><span><svg><use href="#d-key"></use></svg>API Keys</span></nav>
          </div>
          <div class="product-plan"><span>▣</span><span><b>Pro</b><small>10,000 monthly credits</small></span></div>
        </aside>

        <main class="product-main">
          <header class="product-header"><svg><use href="#d-users"></use></svg><b data-dashboard-bind="header">Users</b><label><svg><use href="#d-search"></use></svg><input type="text" placeholder="Search users..." aria-label="Search dashboard" /></label></header>
          <div class="product-content">
            <div class="overview-heading"><div><h3 data-dashboard-bind="title">Users & Credit Limits</h3><p data-dashboard-bind="subtitle">Monitor every user’s credits, limits, and blocked requests.</p></div><div class="dashboard-actions"><button data-dashboard-action="export"><svg><use href="#d-download"></use></svg>Export events</button><button data-dashboard-action="blocked"><svg><use href="#d-shield"></use></svg>View blocked requests</button></div></div>
            <div class="overview-metrics">
              <article><svg><use href="#d-activity"></use></svg><small>Credits consumed</small><b class="purple">68,429</b><span>of 100,000 monthly</span></article>
              <article><svg><use href="#d-battery"></use></svg><small>Credits remaining</small><b class="success">31,571</b><span>renews in 18 days</span></article>
              <article><svg><use href="#d-users"></use></svg><small>Active subscribers</small><b>842</b><span>across paid plans</span></article>
              <article><svg><use href="#d-alert"></use></svg><small>Limits reached</small><b class="danger">18</b><span>users at limit</span></article>
              <article><svg><use href="#d-shield"></use></svg><small>Blocked overspend</small><b class="danger">42</b><span>requests stopped</span></article>
            </div>

            <div class="usage-product-grid">
            <section class="product-chart-card">
              <div class="product-chart-head"><div><b data-dashboard-bind="chart-title">Credit consumption</b><small data-dashboard-bind="chart-note">Consumed credits with 80K limit threshold</small></div><div class="chart-filters"><button class="active" data-range="7d">7d</button><button data-range="30d">30d</button><button data-range="90d">90d</button></div></div>
              <div class="product-chart" aria-label="Credit consumption chart">
                <div class="threshold-line"><span>80K limit threshold</span></div>
                <div class="chart-grid-lines"><i></i><i></i><i></i><i></i><i></i></div>
                <svg viewBox="0 0 800 220" preserveAspectRatio="none" aria-hidden="true">
                  <path class="chart-area" d="M0 185 C80 175 115 170 170 145 S270 110 330 118 S430 145 500 92 S620 62 800 42 L800 220 L0 220 Z" />
                  <path class="revenue-line" d="M0 185 C80 175 115 170 170 145 S270 110 330 118 S430 145 500 92 S620 62 800 42" />
                  <path class="spend-line" d="M0 48 C120 53 210 65 310 78 S510 100 620 128 S730 150 800 170" />
                </svg>
                <div class="chart-labels" data-dashboard-bind="labels"><span>Jun 7</span><span>Jun 8</span><span>Jun 9</span><span>Jun 10</span><span>Jun 11</span><span>Jun 12</span><span>Jun 13</span></div>
              </div>
            </section>

            <section class="highest-usage spend-controls-card">
              <div class="product-chart-head"><div><b>Spend control status</b><small>Protection applied before every model request</small></div></div>
              <div class="control-health"><span class="control-icon"><svg><use href="#d-check"></use></svg></span><div><b>All spend controls healthy</b><small>Every active user has a configured credit ceiling.</small></div></div>
              <div class="control-stat"><span>42</span><div><b>requests blocked</b><small>before overspend this period</small></div></div>
              <div class="control-stat"><span>18</span><div><b>users at limit</b><small>requests paused automatically</small></div></div>
            </section>
            </div>
            <section class="credit-user-table">
              <div class="credit-user-head"><span>User</span><span>Plan</span><span>Credits used</span><span>Remaining</span><span>Usage</span><span>Limit status</span><span>Blocked</span></div>
              <button class="credit-user-row" data-name="John Doe" data-user="john.doe@example.com" data-plan="Pro" data-used="8,412 / 10,000" data-remaining="1,588" data-status="Healthy" data-blocked="0"><span><i>JD</i><b>John Doe<small>john.doe@example.com</small></b></span><span>Pro</span><span>8,412</span><span>1,588</span><strong>84%</strong><em class="healthy">Healthy</em><span>0</span></button>
              <button class="credit-user-row" data-name="Sarah Chen" data-user="sarah@example.com" data-plan="Free" data-used="20 / 20" data-remaining="0" data-status="Limit reached" data-blocked="12"><span><i>SC</i><b>Sarah Chen<small>sarah@example.com</small></b></span><span>Free</span><span>20</span><span>0</span><strong class="danger">100%</strong><em class="reached">Limit reached</em><span>12</span></button>
              <button class="credit-user-row" data-name="Kai Northstar" data-user="kai@northstar.ai" data-plan="Max" data-used="6,091 / 50,000" data-remaining="43,909" data-status="Healthy" data-blocked="0"><span><i>KN</i><b>Kai Northstar<small>kai@northstar.ai</small></b></span><span>Max</span><span>6,091</span><span>43,909</span><strong>12%</strong><em class="healthy">Healthy</em><span>0</span></button>
              <button class="credit-user-row" data-name="Maya Cole" data-user="maya@frame.tools" data-plan="Pro" data-used="4,818 / 10,000" data-remaining="5,182" data-status="Warning" data-blocked="3"><span><i>MC</i><b>Maya Cole<small>maya@frame.tools</small></b></span><span>Pro</span><span>4,818</span><span>5,182</span><strong class="warning">48%</strong><em class="warning">Warning</em><span>3</span></button>
            </section>
            <div class="dashboard-drawer" aria-hidden="true"><button class="drawer-close" data-dashboard-action="close"><svg><use href="#d-x"></use></svg></button><small>User limit details</small><h4 data-drawer-bind="name">John Doe</h4><p data-drawer-bind="email">john.doe@example.com</p><dl><div><dt>Subscription plan</dt><dd data-drawer-bind="plan">Pro</dd></div><div><dt>Credits used</dt><dd data-drawer-bind="used">8,412 / 10,000</dd></div><div><dt>Credits remaining</dt><dd data-drawer-bind="remaining">1,588</dd></div><div><dt>Blocked requests</dt><dd data-drawer-bind="blocked">0</dd></div><div><dt>Limit status</dt><dd data-drawer-bind="status">Healthy</dd></div><div><dt>Recent model requests</dt><dd data-drawer-bind="recent">openai/gpt-4o · flux-schnell</dd></div></dl><button class="drawer-action" data-dashboard-action="increase"><svg><use href="#d-plus"></use></svg>Increase limit</button></div>
            <div class="blocked-modal" aria-hidden="true"><div class="blocked-log"><button class="drawer-close" data-dashboard-action="close-blocked"><svg><use href="#d-x"></use></svg></button><span class="blocked-log-icon"><svg><use href="#d-shield"></use></svg></span><h4>Blocked request log</h4><p>Requests stopped before they could exceed a user’s tier limit.</p><div class="blocked-log-head"><span>User</span><span>Model requested</span><span>Reason</span><span>Timestamp</span></div><div class="blocked-log-row"><span>sarah@example.com</span><span>openai/gpt-4o</span><span>Tier limit reached</span><span>2m ago</span></div><div class="blocked-log-row"><span>maya@frame.tools</span><span>flux-schnell</span><span>Spend control</span><span>18m ago</span></div><div class="blocked-log-row"><span>sarah@example.com</span><span>claude-sonnet</span><span>No credits remaining</span><span>42m ago</span></div></div></div>
            <div class="dashboard-toast" role="status" aria-live="polite"></div>
          </div>
        </main>
      </div>
    </div>
  </div>
</section>

<section class="workflow on-paper">
  <div class="wrap">
    <div class="section-copy enter">
      <h2>A request moves through the whole revenue stack.</h2>
      <p>Your application makes one SDK call. subscribe.dev handles every decision between intent and inference.</p>
    </div>

    <div class="flow-map enter" id="revenue-flow" data-scenario="success" style="--i: 1">
      <div class="revenue-packet" aria-hidden="true">
        <span>AI request</span>
        <b data-revenue-bind="packet">Create request</b>
      </div>
      {flow.map((item, i) => (
        <div class:list={['flow-step', { core: i === 1 }]} data-revenue-step={i}>
          <span>{String(i + 1).padStart(2, '0')}</span>
          <div class="flow-icon">{i === 0 ? 'UI' : i === 1 ? 'S' : i === 2 ? '$' : i === 3 ? '#' : i === 4 ? '✓' : 'AI'}</div>
          <b>{item}</b>
          <small data-revenue-detail>{i === 0 ? 'client.run("openai/gpt-4o")' : i === 1 ? 'resolve user' : i === 2 ? 'verify plan' : i === 3 ? 'reserve credits' : i === 4 ? 'apply policy' : 'stream output'}</small>
        </div>
      ))}
    </div>
    <div class="flow-narration enter" style="--i: 2" aria-live="polite">
      <span data-revenue-bind="step">Step 1 of 6</span>
      <strong data-revenue-bind="narration">Your app asks subscribe.dev to run GPT-4o for this user.</strong>
    </div>
    <div class="flow-console enter" id="revenue-console" style="--i: 3">
      <span class="ok-dot"></span>
      <code data-revenue-bind="request">request req_92c1</code><i></i>
      <code data-revenue-bind="user">user pending</code><i></i>
      <code data-revenue-bind="policy">policy pending</code><i></i>
      <code data-revenue-bind="credits">credits pending</code><i></i>
      <strong data-revenue-bind="status">request received</strong>
    </div>
  </div>
</section>

<section class="cicd">
  <div class="wrap">
    <div class="section-copy enter">
      <h2>Turn your frontend into a subscription-powered AI product.</h2>
