<script>
  const policyRoot = document.getElementById('policy-engine');

  if (policyRoot) {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const publishButton = policyRoot.querySelector<HTMLElement>('[data-policy-bind="button"]')!;
    const deployStatus = policyRoot.querySelector<HTMLElement>('[data-policy-bind="deploy"]')!;
    const cards = [...policyRoot.querySelectorAll<HTMLElement>('[data-policy-plan]')];
    const footerItems = [...policyRoot.querySelectorAll<HTMLElement>('[data-policy-footer]')];
    const badges = cards.map((card) => card.querySelector<HTMLElement>('[data-policy-bind="badge"]')!);
    const creditValues = cards.map((card) => card.querySelector<HTMLElement>('dl div:first-child dd')!);
    const creditTargets = [20, 200, 1000];
    let timers: ReturnType<typeof setTimeout>[] = [];
    let observer: IntersectionObserver | undefined;
    let hasPlayed = false;

    const schedule = (callback: () => void, delay: number) => timers.push(setTimeout(callback, delay));
    const countCredits = (index: number) => {
      const value = creditValues[index];
      const target = creditTargets[index];
      const started = performance.now();
      const tick = (now: number) => {
        const progress = Math.min((now - started) / 800, 1);
        value.textContent = Math.round(target * (1 - Math.pow(1 - progress, 3))).toLocaleString();
        if (progress < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    const finishPolicy = () => {
      policyRoot.classList.remove('is-ready', 'is-publishing', 'is-propagating');
      policyRoot.classList.add('is-visible', 'is-live');
      publishButton.textContent = 'Enforcement live';
      deployStatus.textContent = 'Free locked · Pro + Max operating';
      cards[0]?.classList.remove('is-active', 'is-operating');
      cards[0]?.classList.add('is-complete', 'is-locked');
      badges[0].textContent = '🔒 Limit reached';
      cards.slice(1).forEach((card) => {
        card.classList.remove('is-active');
        card.classList.add('is-complete', 'is-operating');
      });
      badges[1].textContent = '✓ Active';
      badges[2].textContent = '✓ Active';
      footerItems.forEach((item) => item.classList.add('is-complete'));
    };
    const runPolicy = () => {
      if (hasPlayed) return;
      hasPlayed = true;
      creditValues.forEach((value) => (value.textContent = '0'));
      policyRoot.classList.add('is-visible');
      schedule(() => {
        policyRoot.classList.add('is-ready', 'is-cursor-at-button');
        publishButton.textContent = 'Publish changes';
      }, 350);
      schedule(() => {
        policyRoot.classList.add('is-cursor-clicking');
        publishButton.classList.add('is-pressed');
      }, 1350);
      schedule(() => {
        policyRoot.classList.remove('is-cursor-clicking');
        publishButton.classList.remove('is-pressed');
        publishButton.textContent = 'Billing active';
        footerItems[0]?.classList.add('is-active');
      }, 1580);
      schedule(() => {
        policyRoot.classList.remove('is-ready');
        policyRoot.classList.add('is-publishing', 'is-propagating');
        publishButton.textContent = 'Checking access...';
        deployStatus.textContent = 'Billing verified → applying access policy';
        footerItems[0]?.classList.remove('is-active');
        footerItems[0]?.classList.add('is-complete');
        footerItems[1]?.classList.add('is-active');
      }, 2150);
      schedule(() => {
        policyRoot.classList.remove('is-publishing');
        cards[0]?.classList.add('is-active');
        badges[0].textContent = 'Monitoring';
        countCredits(0);
        deployStatus.textContent = 'Free usage climbing toward 20 credits';
      }, 3150);
      schedule(() => {
        cards[0]?.classList.remove('is-active');
        cards[0]?.classList.add('is-complete', 'is-locked');
        badges[0].textContent = '🔒 Limit reached';
        cards[0]!.querySelector<HTMLElement>('[data-policy-bind="plan-status"]')!.textContent = 'Limit enforced';
        footerItems[1]?.classList.remove('is-active');
        footerItems[1]?.classList.add('is-complete');
        footerItems[2]?.classList.add('is-active');
        deployStatus.textContent = 'Free limit reached · access locked';
        publishButton.textContent = 'Limit enforced';
      }, 4250);
      schedule(() => {
        cards[1]?.classList.add('is-active', 'is-operating');
        badges[1].textContent = '✓ Active';
        countCredits(1);
        deployStatus.textContent = 'Pro subscription continues operating';
      }, 5100);
      schedule(() => {
        cards[1]?.classList.remove('is-active');
        cards[1]?.classList.add('is-complete');
        cards[2]?.classList.add('is-active', 'is-operating');
        badges[2].textContent = '✓ Active';
        countCredits(2);
        deployStatus.textContent = 'Max subscription continues operating';
      }, 6200);
      schedule(() => {
        footerItems[2]?.classList.remove('is-active');
        footerItems[2]?.classList.add('is-complete');
        footerItems[3]?.classList.add('is-active');
      }, 7050);
      schedule(finishPolicy, 7800);
    };

    (window as any).__subscribeDevPolicyCleanup?.();
    (window as any).__subscribeDevPolicyCleanup = () => {
      timers.forEach(clearTimeout);
      observer?.disconnect();
    };

    if (reduced) {
      finishPolicy();
    } else {
      observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) runPolicy();
      }, { threshold: 0.25 });
      observer.observe(policyRoot);
    }
  }

  const setupRoot = document.getElementById('setup-demo');

  if (setupRoot) {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const steps = [...setupRoot.querySelectorAll<HTMLElement>('[data-setup-step]')];
    const codeLines = [...setupRoot.querySelectorAll<HTMLElement>('[data-setup-code]')];
    const statuses = [...setupRoot.querySelectorAll<HTMLElement>('[data-setup-status]')];
    const assistantStatus = setupRoot.querySelector<HTMLElement>('[data-setup-bind="assistant-status"]')!;
    const assistantFooter = setupRoot.querySelector<HTMLElement>('[data-setup-bind="assistant-footer"]')!;
    let timers: ReturnType<typeof setTimeout>[] = [];
    let observer: IntersectionObserver | undefined;
    let playing = false;

    const schedule = (callback: () => void, delay: number) => timers.push(setTimeout(callback, delay));
    const resetSetup = () => {
      [...steps, ...codeLines, ...statuses].forEach((item) => item.classList.remove('is-active', 'is-complete'));
      assistantStatus.textContent = 'Ready';
      assistantStatus.classList.remove('is-live');
      assistantFooter.textContent = 'No backend required';
      assistantFooter.classList.remove('is-verified');
    };
    const activateSetup = (index: number) => {
      steps.forEach((step, stepIndex) => {
        step.classList.toggle('is-active', stepIndex === index);
        step.classList.toggle('is-complete', stepIndex < index);
      });
      codeLines.forEach((line, lineIndex) => {
        line.classList.toggle('is-active', lineIndex === index);
        line.classList.toggle('is-complete', lineIndex < index);
      });
    };
    const completeSetup = () => {
      steps.forEach((step) => { step.classList.remove('is-active'); step.classList.add('is-complete'); });
      codeLines.forEach((line) => { line.classList.remove('is-active'); line.classList.add('is-complete'); });
      statuses.forEach((status) => { status.classList.remove('is-active'); status.classList.add('is-complete'); });
      assistantStatus.textContent = 'Live';
      assistantStatus.classList.add('is-live');
      assistantFooter.textContent = 'Stripe subscription tiers connected';
      assistantFooter.classList.add('is-verified');
    };
    const stopSetup = () => {
      playing = false;
      timers.forEach(clearTimeout);
      timers = [];
      observer?.disconnect();
      resetSetup();
    };
    (window as any).__subscribeDevSetupCleanup?.();
    (window as any).__subscribeDevSetupCleanup = stopSetup;

    const runSetup = () => {
      if (!playing) return;
      timers.forEach(clearTimeout);
      timers = [];
      resetSetup();

      schedule(() => activateSetup(0), 550);
      schedule(() => activateSetup(1), 2200);
      schedule(() => {
        statuses[0]?.classList.add('is-active');
        activateSetup(2);
        assistantFooter.textContent = 'Model access verified';
        assistantFooter.classList.add('is-verified');
      }, 3850);
      schedule(() => {
        statuses[0]?.classList.remove('is-active');
        statuses[0]?.classList.add('is-complete');
        statuses[2]?.classList.add('is-active');
        activateSetup(3);
      }, 5500);
      schedule(() => {
        statuses[2]?.classList.remove('is-active');
        statuses[2]?.classList.add('is-complete');
        statuses[1]?.classList.add('is-active');
        assistantFooter.textContent = 'Stripe subscription tiers connected';
      }, 6700);
      schedule(completeSetup, 7700);
      schedule(runSetup, 9600);
    };

    if (reduced) {
      completeSetup();
    } else {
      observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting && !playing) {
          playing = true;
          runSetup();
        } else if (!entry.isIntersecting && playing) {
          playing = false;
          timers.forEach(clearTimeout);
          timers = [];
          resetSetup();
        }
      }, { threshold: 0.25 });
      observer.observe(setupRoot);
    }
  }

  const flowRoot = document.getElementById('request-flow');

  if (flowRoot) {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nodes = [...flowRoot.querySelectorAll<HTMLElement>('[data-flow-node]')];
    const phases = [...flowRoot.querySelectorAll<HTMLElement>('[data-phase]')];
    const outputs = [...flowRoot.querySelectorAll<HTMLElement>('[data-flow-output]')];
    const request = flowRoot.querySelector<HTMLElement>('[data-flow-bind="request"]')!;
    const status = flowRoot.querySelector<HTMLElement>('[data-flow-bind="status"]')!;
    const latency = flowRoot.querySelector<HTMLElement>('[data-flow-bind="latency"]')!;
    const connectorSvg = flowRoot.querySelector<SVGSVGElement>('.architecture-connectors')!;
    const connectorPaths = [...flowRoot.querySelectorAll<SVGPathElement>('[data-connector]')];
    const connectorPulses = [...flowRoot.querySelectorAll<SVGCircleElement>('[data-connector-pulse]')];
    const allTargets = [...nodes, ...phases, ...outputs];
    const connectorCoords = new Map<string, { startX: number; startY: number; endX: number; endY: number }>();
    let timer: ReturnType<typeof setTimeout> | undefined;
    let blocked = true;
    let playing = false;

    const layoutConnectors = () => {
      if (matchMedia('(max-width: 980px)').matches) return;

      const mapRect = flowRoot.getBoundingClientRect();
      const planeRect = flowRoot.querySelector<HTMLElement>('.control-plane')!.getBoundingClientRect();
      connectorSvg.setAttribute('viewBox', `0 0 ${mapRect.width} ${mapRect.height}`);

      connectorPaths.forEach((path) => {
        const name = path.dataset.connector!;
        const source = flowRoot.querySelector<HTMLElement>(
          name === 'user' || name === 'app' ? `[data-flow-node="${name}"]` : `[data-flow-output="${name}"]`,
        );
        if (!source) return;

        const sourceRect = source.getBoundingClientRect();
        const isInput = name === 'user' || name === 'app';
        const startX = (isInput ? sourceRect.right : planeRect.right) - mapRect.left;
        const endX = (isInput ? planeRect.left : sourceRect.left) - mapRect.left;
        const y = sourceRect.top + sourceRect.height / 2 - mapRect.top;

        path.setAttribute('d', `M ${startX} ${y} H ${endX}`);
        connectorCoords.set(name, { startX, startY: y, endX, endY: y });
      });
    };

    const clearTargets = () => {
      allTargets.forEach((el) => el.classList.remove('is-active', 'is-complete'));
      flowRoot.classList.remove('is-left-travel', 'is-right-travel');
      connectorPulses.forEach((pulse) => {
        pulse.classList.remove('is-traveling');
      });
    };

    const activate = (target?: HTMLElement, completed: HTMLElement[] = []) => {
      allTargets.forEach((el) => el.classList.remove('is-active', 'is-complete'));
      completed.forEach((el) => el.classList.add('is-complete'));
      target?.classList.add('is-active');
    };

    const travel = (side: 'left' | 'right', target = side === 'left' ? 'app' : 'models') => {
      flowRoot.classList.remove('is-left-travel', 'is-right-travel');
      void flowRoot.offsetWidth;
      flowRoot.classList.add(side === 'left' ? 'is-left-travel' : 'is-right-travel');

      const pulse = flowRoot.querySelector<SVGCircleElement>(`[data-connector-pulse="${side}"]`);
      const coords = connectorCoords.get(target);
      if (!pulse || !coords || matchMedia('(max-width: 980px)').matches) return;

      pulse.classList.remove('is-traveling');
      pulse.style.setProperty('--pulse-start-x', `${coords.startX}px`);
      pulse.style.setProperty('--pulse-start-y', `${coords.startY}px`);
      pulse.style.setProperty('--pulse-end-x', `${coords.endX}px`);
      pulse.style.setProperty('--pulse-end-y', `${coords.endY}px`);
      void pulse.getBoundingClientRect();
      pulse.classList.add('is-traveling');
      pulse.addEventListener('animationend', () => pulse.classList.remove('is-traveling'), { once: true });
    };

    const runLoop = () => {
      blocked = !blocked;
      flowRoot.dataset.outcome = blocked ? 'blocked' : 'allowed';
      request.textContent = blocked ? 'POST /run/gpt-4o' : 'POST /run/flux-schnell';
      status.textContent = 'checking...';
      latency.textContent = '—';
      clearTargets();

      const completed: HTMLElement[] = [];
      const stages: Array<() => void> = [
        () => activate(nodes[0], completed),
        () => { completed.push(nodes[0]); activate(nodes[1], completed); },
        () => { completed.push(nodes[1]); activate(undefined, completed); travel('left'); },
        () => { flowRoot.classList.remove('is-left-travel'); activate(phases[0], completed); },
        () => { completed.push(phases[0]); activate(phases[1], completed); },
      ];

      if (blocked) {
        stages.push(
          () => { completed.push(phases[1]); activate(outputs[2], completed); travel('right', 'credits'); },
          () => { completed.push(outputs[2]); activate(undefined, completed); status.textContent = 'blocked'; },
          () => { latency.textContent = 'upgrade required'; },
        );
      } else {
        stages.push(
          () => { completed.push(phases[1]); activate(phases[2], completed); },
          () => { completed.push(phases[2]); activate(phases[3], completed); },
          () => { completed.push(phases[3]); activate(outputs[0], completed); travel('right', 'models'); },
          () => { completed.push(outputs[0]); activate(outputs[1], completed); },
          () => { completed.push(outputs[1]); activate(outputs[2], completed); },
          () => { completed.push(outputs[2]); activate(undefined, completed); status.textContent = 'allowed'; },
          () => { latency.textContent = '38 ms'; },
        );
      }

      let index = 0;
      const advance = () => {
        if (!playing) return;
        if (index < stages.length) {
          stages[index++]();
          timer = setTimeout(advance, 560);
        } else {
          timer = setTimeout(runLoop, 1500);
        }
      };
      advance();
    };

    if (reduced) {
      requestAnimationFrame(layoutConnectors);
      flowRoot.dataset.outcome = 'allowed';
      status.textContent = 'allowed';
      latency.textContent = '38 ms';
      allTargets.forEach((el) => el.classList.add('is-complete'));
    } else {
      requestAnimationFrame(layoutConnectors);
      new ResizeObserver(layoutConnectors).observe(flowRoot);
      const observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting && !playing) {
          playing = true;
          runLoop();
        } else if (!entry.isIntersecting && playing) {
          playing = false;
          clearTimeout(timer);
        }
      }, { threshold: 0.25 });
      observer.observe(flowRoot);
    }
  }

  const routerRoot = document.getElementById('model-router');

  if (routerRoot) {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const modelString = routerRoot.querySelector<HTMLElement>('.active-model-string')!;
    const terminal = routerRoot.querySelector<HTMLElement>('[data-router-bind="terminal"]')!;
    const status = routerRoot.querySelector<HTMLElement>('[data-router-bind="status"]')!;
    const rows = [...routerRoot.querySelectorAll<HTMLElement>('[data-model]')];
    const providerBadges = [...routerRoot.querySelectorAll<HTMLElement>('.provider-strip [data-provider]')];
    const routes = [
      { model: 'black-forest-labs/flux-schnell', provider: 'Black Forest Labs', result: 'flux-schnell → -4 credits' },
      { model: 'openai/gpt-4o', provider: 'OpenAI', result: 'gpt-4o → -1 credit' },
      { model: 'wan-video/wan-2.2-5b-fast', provider: 'Wan', result: 'wan-2.2-5b-fast → -18 credits' },
      { model: 'speech/*', provider: 'ElevenLabs', result: 'speech/* → -2 credits' },
      { model: 'claude-sonnet', provider: 'Anthropic', result: 'claude-sonnet → -2 credits' },
      { model: 'gemini-2.5-pro', provider: 'Google', result: 'gemini-2.5-pro → -2 credits' },
    ];
    let routeIndex = 0;
    let timers: ReturnType<typeof setTimeout>[] = [];
    let playing = false;
    let observer: IntersectionObserver | undefined;

    const clearRouter = () => {
      routerRoot.classList.remove('is-code-active', 'is-routing');
      rows.forEach((row) => row.classList.remove('is-active', 'is-complete'));
      providerBadges.forEach((badge) => badge.classList.remove('is-active'));
    };
    const schedule = (callback: () => void, delay: number) => {
      timers.push(setTimeout(callback, delay));
    };
    const stopRouter = () => {
      playing = false;
      timers.forEach(clearTimeout);
      timers = [];
      observer?.disconnect();
      clearRouter();
    };
    (window as any).__subscribeDevModelRouterCleanup?.();
    (window as any).__subscribeDevModelRouterCleanup = stopRouter;

    const beginRoute = () => {
      if (!playing) return;
      const route = routes[routeIndex];
      clearRouter();
      modelString.textContent = `'${route.model}'`;
      terminal.textContent = `${route.model.split('/').pop()} → checking access`;
      status.textContent = 'ROUTING';
      routerRoot.classList.add('is-code-active');

      schedule(() => {
        if (!playing) return;
        routerRoot.classList.remove('is-code-active');
        void routerRoot.offsetWidth;
        routerRoot.classList.add('is-routing');
      }, 650);

      schedule(() => {
        if (!playing) return;
        routerRoot.classList.remove('is-routing');
        rows.find((row) => row.dataset.model === route.model)?.classList.add('is-active');
        providerBadges.find((badge) => badge.dataset.provider === route.provider)?.classList.add('is-active');
        terminal.textContent = route.result;
        status.textContent = 'COMPLETE';
      }, 1400);

      schedule(() => {
        routeIndex = (routeIndex + 1) % routes.length;
        beginRoute();
      }, 3000);
    };

    if (reduced) {
      rows[1]?.classList.add('is-active');
      providerBadges.find((badge) => badge.dataset.provider === 'Black Forest Labs')?.classList.add('is-active');
    } else {
      observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting && !playing) {
          playing = true;
          beginRoute();
        } else if (!entry.isIntersecting && playing) {
          playing = false;
          timers.forEach(clearTimeout);
          timers = [];
          clearRouter();
        }
      }, { threshold: 0.25 });
      observer.observe(routerRoot);
    }
  }

  const revenueRoot = document.getElementById('revenue-flow');
  const revenueConsole = document.getElementById('revenue-console');

  if (revenueRoot && revenueConsole) {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const steps = [...revenueRoot.querySelectorAll<HTMLElement>('[data-revenue-step]')];
    const details = [...revenueRoot.querySelectorAll<HTMLElement>('[data-revenue-detail]')];
    const packet = revenueRoot.querySelector<HTMLElement>('.revenue-packet')!;
    const packetLabel = revenueRoot.querySelector<HTMLElement>('[data-revenue-bind="packet"]')!;
    const narration = document.querySelector<HTMLElement>('.flow-narration')!;
    const narrationStep = narration.querySelector<HTMLElement>('[data-revenue-bind="step"]')!;
    const narrationText = narration.querySelector<HTMLElement>('[data-revenue-bind="narration"]')!;
    const consoleRequest = revenueConsole.querySelector<HTMLElement>('[data-revenue-bind="request"]')!;
    const consoleUser = revenueConsole.querySelector<HTMLElement>('[data-revenue-bind="user"]')!;
    const consolePolicy = revenueConsole.querySelector<HTMLElement>('[data-revenue-bind="policy"]')!;
    const consoleCredits = revenueConsole.querySelector<HTMLElement>('[data-revenue-bind="credits"]')!;
    const consoleStatus = revenueConsole.querySelector<HTMLElement>('[data-revenue-bind="status"]')!;
    const baseDetails = ['client.run("openai/gpt-4o")', 'resolve user', 'verify plan', 'reserve credits', 'apply policy', 'stream output'];
    let timers: ReturnType<typeof setTimeout>[] = [];
    let observer: IntersectionObserver | undefined;
    let playing = false;
    let blocked = true;

    const schedule = (callback: () => void, delay: number) => timers.push(setTimeout(callback, delay));
    const resetVisuals = () => {
      steps.forEach((step) => step.classList.remove('is-active', 'is-complete', 'is-blocked'));
      details.forEach((detail, index) => (detail.textContent = baseDetails[index]));
      revenueRoot.classList.remove('is-traveling', 'is-streaming');
      revenueConsole.classList.remove('is-blocked');
      narration.classList.remove('is-blocked');
      packet.style.setProperty('--token-x', '0px');
    };
    const moveToken = (index: number, reverse = false) => {
      if (innerWidth <= 980) return;
      const distance = steps[index].offsetLeft + steps[index].offsetWidth / 2 - (steps[0].offsetLeft + steps[0].offsetWidth / 2);
      revenueRoot.classList.toggle('is-streaming', reverse);
      revenueRoot.classList.add('is-traveling');
      packet.style.setProperty('--token-x', `${distance}px`);
    };
    const activate = (index: number, detail: string, message: string, packetText: string, blockedStage = false) => {
      steps.forEach((step, stepIndex) => {
        step.classList.toggle('is-active', stepIndex === index && !blockedStage);
        step.classList.toggle('is-blocked', stepIndex === index && blockedStage);
        step.classList.toggle('is-complete', stepIndex < index);
      });
      details[index].textContent = detail;
      narrationStep.textContent = `Step ${index + 1} of 6`;
      narrationText.textContent = message;
      packetLabel.textContent = packetText;
      narration.classList.toggle('is-blocked', blockedStage);
      moveToken(index);
    };
    const stopRevenue = () => {
      playing = false;
      timers.forEach(clearTimeout);
      timers = [];
      observer?.disconnect();
      resetVisuals();
    };
    (window as any).__subscribeDevRevenueFlowCleanup?.();
    (window as any).__subscribeDevRevenueFlowCleanup = stopRevenue;

    const runRevenue = () => {
      if (!playing) return;
      blocked = !blocked;
      resetVisuals();
      revenueRoot.dataset.scenario = blocked ? 'blocked' : 'success';
      consoleRequest.textContent = 'request req_92c1';
      consoleUser.textContent = 'user pending';
      consolePolicy.textContent = 'policy pending';
      consoleCredits.textContent = 'credits pending';
      consoleStatus.textContent = 'request received';
      activate(0, 'client.run("openai/gpt-4o")', 'Your app creates one request for GPT-4o.', 'Create request');

      schedule(() => {
        activate(1, 'user_ada_93 ✓', 'subscribe.dev identifies which user is making the request.', 'Who is this user?');
        consoleUser.textContent = 'user ada_93 ✓';
        consoleStatus.textContent = 'user resolved';
      }, 900);
      schedule(() => {
        activate(2, blocked ? 'Free plan detected ✓' : 'Pro plan detected ✓', blocked ? 'The user is on the Free plan.' : 'The user has an active Pro subscription.', 'Check subscription');
        consolePolicy.textContent = blocked ? 'free policy' : 'pro policy ✓';
        consoleStatus.textContent = blocked ? 'free policy applied' : 'pro policy applied';
      }, 1800);
      schedule(() => {
        activate(3, blocked ? 'limit check ✓' : '-4 credits ✓', blocked ? 'Their remaining allowance is checked before spending.' : 'Four credits are reserved before the model runs.', 'Reserve credits');
        consoleCredits.textContent = blocked ? 'limit reached' : '-4 credits ✓';
        consoleStatus.textContent = blocked ? 'checking access' : '4 credits reserved';
      }, 2700);
      schedule(() => {
        activate(4, blocked ? 'upgrade required' : 'GPT-4o allowed ✓', blocked ? 'GPT-4o is not included on Free, so the request stops here.' : 'The Pro policy allows this user to access GPT-4o.', 'Can they use GPT-4o?', blocked);
        consoleStatus.textContent = blocked ? 'upgrade required' : 'policy granted';
        if (blocked) revenueConsole.classList.add('is-blocked');
      }, 3600);

      if (blocked) {
        schedule(() => {
          consoleStatus.textContent = 'request denied';
        }, 4500);
        schedule(runRevenue, 6200);
      } else {
        schedule(() => {
          activate(5, 'GPT-4o selected ✓', 'The approved request is routed to GPT-4o.', 'Send to GPT-4o');
          consoleStatus.textContent = 'model selected';
        }, 4500);
        schedule(() => {
          steps.forEach((step) => step.classList.add('is-complete'));
          steps.forEach((step) => step.classList.remove('is-active'));
          revenueRoot.classList.add('is-streaming', 'is-traveling');
          narrationStep.textContent = 'Response';
          narrationText.textContent = 'GPT-4o streams the response back through the same secure path.';
          packetLabel.textContent = '50 tokens returned';
          consoleStatus.textContent = 'output streaming... 50 tokens';
          moveToken(4, true);
        }, 5400);
        schedule(() => { consoleStatus.textContent = 'output streaming... 100 tokens'; packetLabel.textContent = '100 tokens returned'; moveToken(2, true); }, 6000);
        schedule(() => { consoleStatus.textContent = 'output streaming... 200 tokens'; packetLabel.textContent = '200 tokens returned'; moveToken(0, true); }, 6600);
        schedule(() => {
          revenueRoot.classList.remove('is-traveling', 'is-streaming');
          consoleStatus.textContent = 'Request completed ✓ · 38ms';
          details[0].textContent = 'response received ✓';
          narrationStep.textContent = 'Complete';
          narrationText.textContent = 'The user receives the response. Billing and usage are already recorded.';
          packetLabel.textContent = 'Response delivered ✓';
        }, 7300);
        schedule(runRevenue, 9000);
      }
    };

    if (reduced) {
      steps.forEach((step) => step.classList.add('is-complete'));
      details[0].textContent = 'response received ✓';
      consoleUser.textContent = 'user ada_93 ✓';
      consolePolicy.textContent = 'pro policy ✓';
      consoleCredits.textContent = '-4 credits ✓';
      consoleStatus.textContent = 'Request completed ✓ · 38ms';
    } else {
      observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting && !playing) {
          playing = true;
          runRevenue();
        } else if (!entry.isIntersecting && playing) {
          playing = false;
          timers.forEach(clearTimeout);
          timers = [];
          resetVisuals();
        }
      }, { threshold: 0.25 });
      observer.observe(revenueRoot);
    }
  }

  const meteringScroll = document.getElementById('metering-scroll');

  if (meteringScroll) {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let ticking = false;

    const updateMeteringScroll = () => {
      const rect = meteringScroll.getBoundingClientRect();
      const viewport = window.innerHeight;
      const travel = Math.max(rect.height - viewport * 0.5, 1);
      const progress = Math.min(1, Math.max(0, (viewport * 0.78 - rect.top) / travel));
      meteringScroll.style.setProperty('--scroll-progress', progress.toFixed(4));
      ticking = false;
    };

    if (reduced) {
      meteringScroll.style.setProperty('--scroll-progress', '1');
    } else {
      const requestUpdate = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(updateMeteringScroll);
      };
      updateMeteringScroll();
      addEventListener('scroll', requestUpdate, { passive: true });
      addEventListener('resize', requestUpdate);
    }
  }

  const usageDashboard = document.getElementById('usage-dashboard');

  if (usageDashboard) {
    const dashboardHeader = usageDashboard.querySelector<HTMLElement>('[data-dashboard-bind="header"]')!;
    const dashboardTitle = usageDashboard.querySelector<HTMLElement>('[data-dashboard-bind="title"]')!;
    const dashboardSubtitle = usageDashboard.querySelector<HTMLElement>('[data-dashboard-bind="subtitle"]')!;
    const chartTitle = usageDashboard.querySelector<HTMLElement>('[data-dashboard-bind="chart-title"]')!;
    const chartNote = usageDashboard.querySelector<HTMLElement>('[data-dashboard-bind="chart-note"]')!;
    const chartLabels = usageDashboard.querySelector<HTMLElement>('[data-dashboard-bind="labels"]')!;
    const drawer = usageDashboard.querySelector<HTMLElement>('.dashboard-drawer')!;
    const blockedModal = usageDashboard.querySelector<HTMLElement>('.blocked-modal')!;
    const toast = usageDashboard.querySelector<HTMLElement>('.dashboard-toast')!;
    let toastTimer: ReturnType<typeof setTimeout> | undefined;

    const showToast = (message: string) => {
      toast.textContent = message;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('show'), 2400);
    };

    const setDrawer = (values: Record<string, string>) => {
      Object.entries(values).forEach(([key, value]) => {
        const field = drawer.querySelector<HTMLElement>(`[data-drawer-bind="${key}"]`);
        if (field) field.textContent = value;
      });
      drawer.classList.add('open');
      drawer.setAttribute('aria-hidden', 'false');
    };

    const closeDrawer = () => {
      drawer.classList.remove('open');
      drawer.setAttribute('aria-hidden', 'true');
    };

    const showBlockedRequests = () => {
      closeDrawer();
      blockedModal.classList.add('open');
      blockedModal.setAttribute('aria-hidden', 'false');
    };

    const closeBlockedRequests = () => {
      blockedModal.classList.remove('open');
      blockedModal.setAttribute('aria-hidden', 'true');
    };

    usageDashboard.addEventListener('click', (event) => {
      const target = (event.target as HTMLElement).closest<HTMLElement>('button');
      if (!target) return;

      const view = target.dataset.dashboardView;
      const range = target.dataset.range;
      const action = target.dataset.dashboardAction;
      const user = target.dataset.user;

      if (view === 'Users') {
        dashboardHeader.textContent = 'Users';
        dashboardTitle.textContent = 'Users & Credit Limits';
        dashboardSubtitle.textContent = 'Monitor every user’s credits, limits, and blocked requests.';
        showToast('Users credit limits view');
      }

      if (range) {
        usageDashboard.querySelectorAll('[data-range]').forEach((item) => item.classList.toggle('active', item === target));
        const labels: Record<string, string[]> = {
          '7d': ['Jun 7', 'Jun 8', 'Jun 9', 'Jun 10', 'Jun 11', 'Jun 12', 'Jun 13'],
          '30d': ['May 15', 'May 20', 'May 25', 'May 30', 'Jun 4', 'Jun 9', 'Jun 13'],
          '90d': ['Mar 15', 'Mar 30', 'Apr 15', 'Apr 30', 'May 15', 'May 30', 'Jun 13'],
        };
        chartLabels.innerHTML = labels[range].map((label) => `<span>${label}</span>`).join('');
        chartNote.textContent = `${range} view · ${range === '7d' ? '68,429' : range === '30d' ? '246,180' : '681,902'} credits consumed`;
      }

      if (user) {
        closeBlockedRequests();
        setDrawer({
          name: target.dataset.name ?? 'User',
          email: user,
          plan: target.dataset.plan ?? 'Pro',
          used: target.dataset.used ?? '0',
          remaining: target.dataset.remaining ?? '0',
          blocked: target.dataset.blocked ?? '0',
          status: target.dataset.status ?? 'Healthy',
          recent: target.dataset.status === 'Limit reached' ? 'gpt-4o · blocked · tier limit reached' : 'openai/gpt-4o · flux-schnell',
        });
      }

      if (action === 'close') closeDrawer();
      if (action === 'close-blocked') closeBlockedRequests();
      if (action === 'export') showToast('Usage events exported');
      if (action === 'blocked') showBlockedRequests();
      if (action === 'increase') {
        showToast('Limit increased for this user.');
        closeDrawer();
      }
    });
  }
</script>
