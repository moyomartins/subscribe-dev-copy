  .setup-code-line.is-active { opacity: 1; background: oklch(0.72 0.14 155 / 0.12); box-shadow: inset 2px 0 0 oklch(0.72 0.14 155), 0 0 20px oklch(0.72 0.14 155 / 0.13); transform: translateX(3px); }
